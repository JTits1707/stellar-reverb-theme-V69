<div class="fa-relic-layer" aria-hidden="true">
  {% for i in (1..14) %}
    {% assign size = forloop.index | modulo: 5 | plus: 4 %}
    {% assign left = forloop.index | times: 73 | modulo: 100 %}
    {% assign top = forloop.index | times: 41 | modulo: 100 %}
    {% assign duration = forloop.index | modulo: 5 | plus: 10 %}
    <span class="fa-dust" style="--s: {{ size }}px; --x: {{ left }}%; --y: {{ top }}%; --d: {{ duration }}s; --b: {{ forloop.index | modulo: 3 }}px; --o: .{{ forloop.index | modulo: 5 | plus: 22 }};"></span>
  {% endfor %}
</div>
{% schema %}
{"name":"FA 03 · Floating Relics","tag":"section","class":"section-fa-relics","settings":[],"presets":[{"name":"FA 03 · Floating Relics"}]}
{% endschema %}
