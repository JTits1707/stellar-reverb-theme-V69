<section class="fa-section fa-relic-grid">
  <div class="fa-grid-head">
    <h2 class="fa-display fa-section-title">{{ section.settings.title }}</h2>
    <p class="fa-copy">{{ section.settings.subtext }}</p>
  </div>
  {% assign collection_handle = section.settings.collection_handle | default: 'floatin-archive' %}
  {% assign archive_collection = collections[collection_handle] %}
  {% if archive_collection != blank and archive_collection.products_count > 0 %}
    <div class="fa-product-grid">
      {% for product in archive_collection.products limit: 12 %}
        {% assign fa_num = forloop.index | prepend: '00' | slice: -3, 3 %}
        <article class="fa-product-card" data-fa-tilt>
          <a class="fa-product-media" href="{{ product.url }}" aria-label="View {{ product.title | escape }}">
            {% if product.featured_image %}
              {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 33vw, (min-width: 640px) 50vw, 100vw', alt: product.title }}
            {% endif %}
          </a>
          <div class="fa-product-info">
            <h3 class="fa-product-title">{{ product.title }}</h3>
            <div class="fa-stamp">FA·{{ fa_num }}</div>
            <div class="fa-price">{{ product.price | money }}</div>
            {% if product.available and product.selected_or_first_available_variant %}
              {% form 'product', product, class: 'fa-quick-add' %}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button class="fa-button" type="submit">Add to rotation</button>
              {% endform %}
            {% else %}
              <a class="fa-button fa-product-link" href="{{ product.url }}">View relic</a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="fa-empty-grid">
      <h3 class="fa-display">The wall is waiting.</h3>
      <p class="fa-copy">Assign products to the <span class="fa-mono">{{ collection_handle }}</span> collection and the twelve-piece rotation will appear here.</p>
    </div>
  {% endif %}
</section>
{% schema %}
{
  "name":"FA 06 · Relic Grid",
  "tag":"section",
  "class":"section-fa-grid",
  "settings":[
    {"type":"text","id":"title","label":"Title","default":"In rotation"},
    {"type":"text","id":"subtext","label":"Subtext","default":"Twelve pieces. Pulled from the static. Limited runs."},
    {"type":"text","id":"collection_handle","label":"Archive collection handle","default":"floatin-archive","info":"Collection handle used for the dynamic relic grid."}
  ],
  "presets":[{"name":"FA 06 · Relic Grid"}]
}
{% endschema %}
