<section class="fa-section fa-next-drop" style="--fa-next-bg: url({{ 'floatin-archive-next-drop-bg.jpg' | asset_url }});">
  <div class="fa-frequency-card">
    <h2 class="fa-display fa-section-title">{{ section.settings.title }}</h2>
    <p class="fa-copy">{{ section.settings.subtext }}</p>
    {% form 'customer', id: 'floatin-archive-frequency', class: 'fa-frequency-form' %}
      <input type="hidden" name="contact[tags]" value="floatin-archive,next-drop-frequency">
      <label class="fa-email-label" for="fa-frequency-email">{{ section.settings.email_label }}</label>
      <input id="fa-frequency-email" type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" required>
      <button class="fa-button" type="submit">{{ section.settings.submit_text }}</button>
      {% if form.posted_successfully? %}<p class="fa-form-success">{{ section.settings.confirmation }}</p>{% endif %}
      {% if form.errors %}<p class="fa-form-success">{{ form.errors | default_errors }}</p>{% endif %}
    {% endform %}
    <p class="fa-microcopy">{{ section.settings.microcopy }}</p>
  </div>
</section>
{% schema %}
{
  "name":"FA 08 · Next Drop Email",
  "tag":"section",
  "class":"section-fa-next-drop",
  "settings":[
    {"type":"text","id":"title","label":"Title","default":"Next drop incoming"},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"More transmissions are tuning up. Small runs. No warnings — unless you want one."},
    {"type":"text","id":"email_label","label":"Email label","default":"Leave your frequency. Get the heads up before Side A."},
    {"type":"text","id":"placeholder","label":"Placeholder","default":"your@signal.com"},
    {"type":"text","id":"submit_text","label":"Submit button","default":"Tune me in"},
    {"type":"text","id":"confirmation","label":"Confirmation","default":"You're on the frequency. We'll be in touch before the next drop."},
    {"type":"text","id":"microcopy","label":"Microcopy","default":"No spam. Just drops. Unsubscribe anytime."}
  ],
  "presets":[{"name":"FA 08 · Next Drop Email"}]
}
{% endschema %}
