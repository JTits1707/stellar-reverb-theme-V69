{% if section.settings.enable_gate %}
  <div class="fa-access-gate" data-fa-gate>
    <div class="fa-gate-card">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 420 | image_tag: class: 'fa-gate-logo', loading: 'eager', alt: 'Stellar Reverb Floatin Archive logo' }}
      {% else %}
        <img class="fa-gate-logo" src="{{ 'floatin-archive-logo.jpeg' | asset_url }}" alt="Stellar Reverb Floatin Archive logo" loading="eager">
      {% endif %}
      <h1 class="fa-display fa-gate-title">{{ section.settings.title }}</h1>
      <p class="fa-gate-message">{{ section.settings.message }}</p>
      <button class="fa-button" type="button" data-fa-gate-button>{{ section.settings.button_text }}</button>
      <div class="fa-gate-notice">{{ section.settings.notice }}</div>
    </div>
  </div>
{% endif %}
{% schema %}
{
  "name":"FA 02 · Access Gate",
  "tag":"section",
  "class":"section-fa-gate",
  "settings":[
    {"type":"checkbox","id":"enable_gate","label":"Enable front-end curtain gate","default":true},
    {"type":"image_picker","id":"logo","label":"Archive logo override"},
    {"type":"text","id":"title","label":"Title","default":"You found it."},
    {"type":"textarea","id":"message","label":"Message","default":"Most people walk right past this door. Push through if you know."},
    {"type":"text","id":"button_text","label":"Button","default":"Pull the curtain"},
    {"type":"text","id":"notice","label":"Notice","default":"Stay as long as you want. The universe will wait."}
  ],
  "presets":[{"name":"FA 02 · Access Gate"}]
}
{% endschema %}
