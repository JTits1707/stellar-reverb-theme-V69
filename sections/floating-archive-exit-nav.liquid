<section class="fa-section fa-exit">
  <a class="fa-display" href="{{ section.settings.exit_url }}">{{ section.settings.exit_link }}</a>
  <p class="fa-exit-note">{{ section.settings.note }}</p>
</section>
{% schema %}
{
  "name":"FA 09 · Exit Nav",
  "tag":"section",
  "class":"section-fa-exit",
  "settings":[
    {"type":"url","id":"exit_url","label":"Exit URL","default":"/collections/shop-all"},
    {"type":"text","id":"exit_link","label":"Exit link","default":"Back to the main floor"},
    {"type":"text","id":"note","label":"Note","default":"The Archive isn't going anywhere. Come back whenever."}
  ],
  "presets":[{"name":"FA 09 · Exit Nav"}]
}
{% endschema %}
