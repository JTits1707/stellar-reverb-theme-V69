{% comment %}
  STELLAR REVERB — FLOATIN' ARCHIVE
  Legacy compatibility section. The active Shopify OS 2.0 page uses the modular
  FA 01–09 sections in templates/page.floating-archive.json.
{% endcomment %}

{{ 'floatin-archive-page.css' | asset_url | stylesheet_tag }}
<script src="{{ 'floatin-archive-page.js' | asset_url }}" defer></script>

<section class="fa-section fa-manifest">
  <article class="fa-manifest-card">
    <div class="fa-mono fa-runtime">Side B · 04:21</div>
    <h1 class="fa-display fa-section-title">FLOATIN' ARCHIVE</h1>
    <div class="fa-copy">
      <p>The Floatin' Archive is the back room of Stellar Reverb. Past the wooden beads, down the hall, behind the door nobody points at.</p>
      <p>This fallback section exists for older page assignments. For the full experience, assign the <span class="fa-mono">page.floating-archive</span> template.</p>
    </div>
  </article>
</section>

{% schema %}
{
  "name": "Floatin' Archive · Fallback",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "Floatin' Archive · Fallback"
    }
  ]
}
{% endschema %}
