<section class="fa-section fa-hero" data-fa-hero style="--fa-hero: url({{ 'floatin-archive-hero.jpg' | asset_url }});">
  <div class="fa-hero-content">
    <div class="fa-kicker fa-now-playing">{{ section.settings.system_line }}</div>
    <h1 class="fa-display fa-hero-title">{{ section.settings.title }}</h1>
    <span class="fa-tagline">{{ section.settings.tagline }}</span>
    <p class="fa-copy fa-subtext">{{ section.settings.subtext }}</p>
  </div>
</section>
{% schema %}
{
  "name":"FA 04 · Hero",
  "tag":"section",
  "class":"section-fa-hero",
  "settings":[
    {"type":"text","id":"system_line","label":"System line","default":"Now playing: Side B"},
    {"type":"text","id":"title","label":"Title","default":"FLOATIN' ARCHIVE"},
    {"type":"text","id":"tagline","label":"Tagline","default":"Back porch of the universe."},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"Limited drops. Lost transmissions. References only the right people clock."}
  ],
  "presets":[{"name":"FA 04 · Hero"}]
}
{% endschema %}
