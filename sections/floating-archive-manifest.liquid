<section class="fa-section fa-manifest">
  <article class="fa-manifest-card">
    <div class="fa-mono fa-runtime">Side B · 04:21</div>
    <h2 class="fa-display fa-section-title">{{ section.settings.title }}</h2>
    <div class="fa-copy">
      <p>The Floatin' Archive is the back room of Stellar Reverb. Past the wooden beads, down the hall, behind the door nobody points at.</p>
      <p>This is where the Signal Seekers go when the broadcast cuts and the throne can wait. Limited drops. Lost transmissions. References only the right people clock.</p>
      <p>Stay as long as you want. The universe will wait.</p>
    </div>
    <div class="fa-manifest-foot fa-mono">{{ section.settings.footer_microcopy }}</div>
  </article>
</section>
{% schema %}
{
  "name":"FA 05 · Manifest",
  "tag":"section",
  "class":"section-fa-manifest",
  "settings":[
    {"type":"text","id":"title","label":"Title","default":"Where am I?"},
    {"type":"text","id":"footer_microcopy","label":"Footer microcopy","default":"Each drop is small on purpose. When they're gone, they're gone."}
  ],
  "presets":[{"name":"FA 05 · Manifest"}]
}
{% endschema %}
