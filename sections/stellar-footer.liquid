{% comment %}
  STELLAR REVERB — FOOTER SECTION
  Safe global footer for layout/theme.liquid.
{% endcomment %}
{% liquid
  assign all_capsules = metaobjects.capsule.values | sort: 'capsule_number'
  assign show_signal_badge = section.settings.show_signal_badge
  assign copyright_text = section.settings.copyright_text
%}

<footer class="stellar-footer" data-section-id="{{ section.id }}" role="contentinfo">
  <div class="stellar-footer__inner page-width">
    <div class="stellar-footer__grid">
      <div class="stellar-footer__column">
        <h2 class="stellar-footer__heading">Capsules</h2>
        <ul class="stellar-footer__links" role="list">
          {% if all_capsules != blank %}
            {% for capsule in all_capsules limit: 8 %}
              <li>
                <a class="stellar-footer__link" href="{{ capsule.page_url.value | default: '/collections/all' }}">
                  <span>{{ capsule.capsule_number.value | default: forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                  {{ capsule.title.value | default: capsule.system.handle | replace: '-', ' ' | capitalize }}
                </a>
              </li>
            {% endfor %}
          {% else %}
            <li><a class="stellar-footer__link" href="/collections/all">Shop All</a></li>
            <li><a class="stellar-footer__link" href="/pages/lore">Lore</a></li>
            <li><a class="stellar-footer__link" href="/pages/contact">Contact</a></li>
          {% endif %}
        </ul>
      </div>

      <div class="stellar-footer__column">
        <h2 class="stellar-footer__heading">Info</h2>
        <ul class="stellar-footer__links" role="list">
          {% for block in section.blocks %}
            {% if block.type == 'info_link' and block.settings.label != blank %}
              <li {{ block.shopify_attributes }}><a class="stellar-footer__link" href="{{ block.settings.url | default: '#' }}">{{ block.settings.label }}</a></li>
            {% endif %}
          {% endfor %}
          <li><a class="stellar-footer__link" href="/policies/shipping-policy">Shipping</a></li>
          <li><a class="stellar-footer__link" href="/policies/refund-policy">Returns</a></li>
        </ul>
      </div>

      <div class="stellar-footer__column">
        <h2 class="stellar-footer__heading">Signal</h2>
        <p class="stellar-footer__copy">Tune into new drops, capsule lore, and transmissions from Stellar Reverb.</p>
        {% if show_signal_badge %}
          <div class="stellar-footer__badge" aria-label="Signal Seeker active">
            <span></span> Signal Seeker
          </div>
        {% endif %}
      </div>
    </div>

    <div class="stellar-footer__bottom">
      <p>{{ copyright_text }}</p>
      <p class="stellar-footer__small">All signals archived. All transmissions encrypted.</p>
    </div>
  </div>
</footer>

<style>
  .stellar-footer {
    background: radial-gradient(circle at 20% 0%, rgba(255, 0, 255, 0.16), transparent 34%), linear-gradient(180deg, #090912 0%, #030306 100%);
    border-top: 1px solid rgba(0, 240, 255, 0.24);
    color: rgba(255,255,255,0.82);
    padding: clamp(3rem, 7vw, 6rem) 0 2rem;
  }
  .stellar-footer__inner { max-width: 1220px; margin: 0 auto; padding: 0 1.5rem; }
  .stellar-footer__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: clamp(2rem, 5vw, 4rem); }
  .stellar-footer__heading { margin: 0 0 1rem; color: #00f0ff; font-size: 0.9rem; letter-spacing: 0.2em; text-transform: uppercase; }
  .stellar-footer__links { display: grid; gap: 0.75rem; margin: 0; padding: 0; list-style: none; }
  .stellar-footer__link { color: rgba(255,255,255,0.78); text-decoration: none; letter-spacing: 0.08em; text-transform: uppercase; font-size: 0.78rem; }
  .stellar-footer__link:hover { color: #ff00ff; text-shadow: 0 0 14px rgba(255,0,255,0.55); }
  .stellar-footer__copy { max-width: 28rem; line-height: 1.7; color: rgba(255,255,255,0.68); }
  .stellar-footer__badge { display: inline-flex; align-items: center; gap: 0.55rem; margin-top: 1rem; padding: 0.75rem 1rem; border: 1px solid rgba(0,240,255,0.35); border-radius: 999px; color: #00f0ac; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.75rem; }
  .stellar-footer__badge span { width: 0.55rem; height: 0.55rem; border-radius: 999px; background: #00f0ac; box-shadow: 0 0 18px #00f0ac; }
  .stellar-footer__bottom { display: flex; justify-content: space-between; gap: 1rem; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.58); font-size: 0.8rem; }
  .stellar-footer__small { text-align: right; }
  @media (max-width: 800px) {
    .stellar-footer__grid { grid-template-columns: 1fr; }
    .stellar-footer__bottom { display: grid; }
    .stellar-footer__small { text-align: left; }
  }
</style>

{% schema %}
{
  "name": "Stellar footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_signal_badge",
      "label": "Show Signal Seeker badge",
      "default": true
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "© 2026 Stellar Reverb. All transmissions encrypted."
    }
  ],
  "blocks": [
    {
      "type": "info_link",
      "name": "Info link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "FAQ" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [
    { "name": "Stellar footer" }
  ]
}
{% endschema %}
